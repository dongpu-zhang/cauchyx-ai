# ── Composites ────────────────────────────────────────────────────

pde:CFRP a pde:Composite ;
    rdfs:label "cfrp" ;
    pde:thermalConductivity    "40.0"^^xsd:double ;   # in-plane
    pde:density                "1600.0"^^xsd:double ;
    pde:specificHeatCapacity   "800.0"^^xsd:double ;
    pde:thermalDiffusivity     "3.125e-5"^^xsd:double ;
    pde:applicationDomain      "Carbon fiber: aerospace, Formula 1, wind turbines" .

pde:Concrete a pde:Composite ;
    rdfs:label "concrete" ;
    pde:thermalConductivity    "1.7"^^xsd:double ;
    pde:density                "2300.0"^^xsd:double ;
    pde:specificHeatCapacity   "880.0"^^xsd:double ;
    pde:thermalDiffusivity     "8.399e-7"^^xsd:double ;
    pde:applicationDomain      "Civil engineering, nuclear containment, bridges" .
