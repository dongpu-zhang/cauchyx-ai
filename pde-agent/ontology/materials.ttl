    pde:density                "3600.0"^^xsd:double ;
    pde:specificHeatCapacity   "1000.0"^^xsd:double ;
    pde:thermalDiffusivity     "2.778e-7"^^xsd:double ;
    pde:applicationDomain      "LiFePO4 cathode: EV battery packs (CATL, BYD)" .

pde:NMC811 a pde:BatteryMaterial ;
    rdfs:label "nmc811" ;
    pde:thermalConductivity    "1.5"^^xsd:double ;
    pde:density                "4800.0"^^xsd:double ;
    pde:specificHeatCapacity   "900.0"^^xsd:double ;
    pde:thermalDiffusivity     "3.472e-7"^^xsd:double ;
    pde:applicationDomain      "NMC-811 cathode: high-energy EV batteries" .

# ── Ceramics ─────────────────────────────────────────────────────

pde:Alumina a pde:Ceramic ;
    rdfs:label "alumina" ;
    pde:casNumber              "1344-28-1" ;
    pde:thermalConductivity    "30.0"^^xsd:double ;
    pde:density                "3960.0"^^xsd:double ;
    pde:specificHeatCapacity   "880.0"^^xsd:double ;
    pde:thermalDiffusivity     "8.607e-6"^^xsd:double ;
    pde:applicationDomain      "Substrates, insulators, refractories" .

pde:SiliconCarbide a pde:Ceramic ;
    rdfs:label "sic" ;
    pde:casNumber              "409-21-2" ;
    pde:thermalConductivity    "120.0"^^xsd:double ;
